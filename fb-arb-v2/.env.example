# ─── SOCIAVAULT (Primary FB Marketplace Source) ──────────────────────────────
# Get from: https://sociavault.com (free tier: 100 req/day, Starter: 1,000/day)
SOCIAVAULT_API_KEY=your_sociavault_key_here

# ─── EBAY FINDING API ────────────────────────────────────────────────────────
# Get from: https://developer.ebay.com/my/keys → Production → Finding API
EBAY_APP_ID=your_ebay_app_id_here

# ─── SUPABASE ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── TELEGRAM ────────────────────────────────────────────────────────────────
# Create bot: message @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your chat ID: message @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── ANTHROPIC ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── SEARCH LOCATION ─────────────────────────────────────────────────────────
# City for FB Marketplace search (resolved to lat/lng via SociaVault)
SEARCH_LOCATION_QUERY=Salt Lake City, UT
# Search radius in km (40km ≈ 25 miles)
SEARCH_RADIUS_KM=40

# ─── PIPELINE SCHEDULE ───────────────────────────────────────────────────────
# How often to run the sourcing pipeline
PIPELINE_CRON=*/30 * * * *
# When to run the Brain (default: Sunday at midnight)
BRAIN_CRON=0 0 * * 0

# ─── OPTIONAL: APIFY FALLBACK ────────────────────────────────────────────────
# Only needed if SociaVault is down. Actor: curious_coder/facebook-marketplace
APIFY_TOKEN=
