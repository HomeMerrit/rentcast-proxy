# The public URL of the AgentOS backend API (FastAPI).
# In Vercel: Project → Settings → Environment Variables.
NEXT_PUBLIC_API_URL=https://backend-production-a20b.up.railway.app

# Optional: point streaming (SSE) at the backend too (defaults to NEXT_PUBLIC_API_URL host).
NEXT_PUBLIC_STREAM_URL=https://backend-production-a20b.up.railway.app

# Optional: require an API key in the browser (off by default for piloting).
NEXT_PUBLIC_REQUIRE_AUTH=false
